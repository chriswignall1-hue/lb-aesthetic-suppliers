---
// HeroSection.astro
interface Props {
  featuredProducts: Array<{ name: string; slug: string; image1?: string; price: number; priceTBC: boolean }>;
}
const { featuredProducts } = Astro.props;
---

<section
  id="hero"
  class="relative min-h-[90vh] flex items-center overflow-hidden bg-cream"
>
  <!-- Gradient blob decorations -->
  <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full opacity-20 bg-brand-gradient blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-20 -left-20 w-80 h-80 rounded-full opacity-15 bg-brand-gradient blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- Left: Text content -->
      <div class="text-center lg:text-left">
        <!-- Pill badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-gradient-soft border border-pink-100 mb-6">
          <span class="w-2 h-2 rounded-full bg-brand-gradient inline-block" style="background: linear-gradient(135deg,#FF6B4A,#D4148A)"></span>
          <span class="text-sm font-medium text-pink-700">Professional Aesthetic Supplies</span>
        </div>

        <!-- Headline -->
        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 leading-tight mb-6">
          Everything your<br />
          <span class="bg-brand-gradient bg-clip-text text-transparent">salon needs,</span><br />
          delivered.
        </h1>

        <!-- Subheadline -->
        <!-- TODO: replace with real copy before going live -->
        <p class="text-lg text-gray-600 leading-relaxed mb-8 max-w-lg mx-auto lg:mx-0">
          Premium-quality aesthetic supplies sourced for beauty professionals.
          From gloves to equipment, skincare to sterilisation — we've got your treatment room covered.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a
            href="#shop"
            class="px-8 py-4 rounded-full font-semibold text-white bg-brand-gradient shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-200 text-center"
          >
            Shop the Range
          </a>
          <a
            href="#how-to-order"
            class="px-8 py-4 rounded-full font-semibold text-gray-700 bg-white border border-gray-200 hover:border-pink-300 hover:text-pink-600 transition-all duration-200 text-center"
          >
            How to Order
          </a>
        </div>

        <!-- Trust badges -->
        <div class="mt-10 flex flex-wrap gap-6 justify-center lg:justify-start text-sm text-gray-500">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Professional Grade
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Fast Dispatch
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Competitive Pricing
          </div>
        </div>
      </div>

      <!-- Right: Hot products panel -->
      <div class="hidden lg:flex flex-col gap-4">
        <!-- Panel header -->
        <div class="flex items-center gap-3">
          <div class="flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-gradient shadow-sm">
            <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/>
            </svg>
            <span class="text-xs font-bold text-white uppercase tracking-widest">Hot Products</span>
          </div>
          <div class="flex-1 h-px bg-gradient-to-r from-pink-200 to-transparent"></div>
        </div>

        <!-- 2×2 product grid -->
        <div class="grid grid-cols-2 gap-4">
          {featuredProducts.slice(0, 4).map((p, i) => (
            <a
              href="#shop"
              class={`group bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 flex flex-col ${i % 2 === 1 ? 'mt-5' : ''}`}
            >
              <!-- Product image -->
              <div class="aspect-square overflow-hidden bg-cream-dark">
                <img
                  src={p.image1 || '/images/products/placeholder-gloves.svg'}
                  alt={p.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="eager"
                />
              </div>
              <!-- Card footer -->
              <div class="px-3 py-2.5">
                <p class="text-xs font-semibold text-gray-800 leading-snug line-clamp-2">{p.name}</p>
                <div class="flex items-center justify-between mt-1">
                  <p class="text-sm font-bold text-gray-900">£{p.price.toFixed(2)}</p>
                  {p.priceTBC && (
                    <span class="text-[10px] text-amber-600 font-medium">TBC</span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>

        <p class="text-xs text-center text-gray-400">Click any product to browse the full range</p>
      </div>
    </div>
  </div>

  <!-- Gradient divider -->
  <div class="absolute bottom-0 left-0 right-0 h-1 bg-brand-gradient"></div>
</section>
