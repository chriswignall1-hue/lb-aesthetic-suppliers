---
// OrderSidebar.astro — floating order basket + checkout form + confirmation
---

<!-- Floating basket button (mobile) -->
<button
  id="basket-toggle"
  class="fixed bottom-6 right-6 z-40 flex items-center gap-2 px-5 py-3 rounded-full text-white font-semibold shadow-xl bg-brand-gradient hover:scale-105 transition-all duration-200 md:hidden"
  aria-label="View order"
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-4H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
  </svg>
  <span>Order</span>
  <span
    id="basket-count-badge"
    class="hidden bg-white text-pink-600 text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center"
  >0</span>
</button>

<!-- Sidebar overlay -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/40 z-40 hidden opacity-0 transition-opacity duration-300"></div>

<!-- Sidebar panel -->
<aside
  id="order-sidebar"
  class="fixed top-0 right-0 h-full w-full sm:w-[420px] z-50 bg-white shadow-2xl flex flex-col transform translate-x-full transition-transform duration-300 ease-in-out"
  aria-label="Order summary"
>
  <!-- Header -->
  <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
    <div>
      <h2 class="font-serif font-bold text-xl text-gray-900">Your Order</h2>
      <p class="text-sm text-gray-500 mt-0.5">Review items before submitting</p>
    </div>
    <button id="close-sidebar" class="p-2 rounded-lg text-gray-400 hover:bg-gray-100 hover:text-gray-600 transition-colors" aria-label="Close order panel">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Scrollable body -->
  <div class="flex-1 overflow-y-auto">

    <!-- Empty state -->
    <div id="empty-basket" class="flex flex-col items-center justify-center h-64 px-6 text-center">
      <svg class="w-12 h-12 text-gray-200 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
      </svg>
      <p class="text-gray-400 font-medium">Your order is empty</p>
      <p class="text-sm text-gray-300 mt-1">Add products from the shop</p>
    </div>

    <!-- Order items list -->
    <div id="order-items" class="hidden px-6 py-4 space-y-3"></div>

    <!-- Order total -->
    <div id="order-total-section" class="hidden px-6 pb-4">
      <div class="flex justify-between items-center py-3 border-t border-gray-100">
        <span class="font-semibold text-gray-700">Estimated Total</span>
        <span id="order-total" class="font-bold text-xl text-gray-900">£0.00</span>
      </div>
    </div>

    <!-- Checkout form -->
    <div id="checkout-form-section" class="hidden px-6 pb-6">
      <h3 class="font-serif font-semibold text-gray-900 text-lg mb-4 pt-4 border-t border-gray-100">Your Details</h3>

      <!-- Netlify form — hidden inputs required for form detection -->
      <form
        id="order-form"
        name="order-enquiry"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="space-y-4"
        novalidate
      >
        <!-- Netlify hidden fields -->
        <input type="hidden" name="form-name" value="order-enquiry" />
        <input type="hidden" name="order-items" id="hidden-order-items" />
        <input type="hidden" name="order-total" id="hidden-order-total" />

        <!-- Honeypot (bot trap) -->
        <div style="display:none">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="customer-name">Full Name *</label>
          <input
            type="text"
            id="customer-name"
            name="customer-name"
            required
            class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-pink-400"
            placeholder="Jane Smith"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="customer-email">Email Address *</label>
          <input
            type="email"
            id="customer-email"
            name="customer-email"
            required
            class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-pink-400"
            placeholder="jane@yoursalon.com"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="customer-phone">Phone Number *</label>
          <input
            type="tel"
            id="customer-phone"
            name="customer-phone"
            required
            class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-pink-400"
            placeholder="07700 000000"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="delivery-address">Delivery Address *</label>
          <textarea
            id="delivery-address"
            name="delivery-address"
            required
            rows="3"
            class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-pink-400 resize-none"
            placeholder="123 High Street&#10;Manchester&#10;M1 1AA"
          ></textarea>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="order-notes">Order Notes (optional)</label>
          <textarea
            id="order-notes"
            name="order-notes"
            rows="2"
            class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-pink-400 resize-none"
            placeholder="Any special requirements or delivery instructions..."
          ></textarea>
        </div>

        <button
          type="submit"
          id="submit-order-btn"
          class="w-full py-4 rounded-xl font-semibold text-white bg-brand-gradient hover:shadow-lg hover:scale-[1.02] transition-all duration-200"
        >
          Place Order
        </button>

        <p class="text-xs text-gray-400 text-center leading-relaxed">
          By placing an order you agree to pay via bank transfer within 48 hours.
          Your order will be confirmed by email.
        </p>
      </form>
    </div>

    <!-- Order confirmation (shown after submit) -->
    <div id="order-confirmation" class="hidden px-6 py-8">
      <div class="text-center mb-6">
        <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h3 class="font-serif font-bold text-xl text-gray-900 mb-2">Order Received!</h3>
        <p class="text-sm text-gray-500">Thank you — we'll be in touch shortly to confirm your order.</p>
      </div>

      <!-- Order summary recap -->
      <div class="bg-cream rounded-2xl p-4 mb-6">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Order Summary</p>
        <div id="confirmation-items" class="space-y-2 text-sm text-gray-700"></div>
        <div class="border-t border-gray-200 mt-3 pt-3 flex justify-between font-semibold">
          <span>Total</span>
          <span id="confirmation-total">£0.00</span>
        </div>
      </div>

      <!-- Bank transfer instructions -->
      <!-- TODO: replace with real bank details before going live -->
      <div class="bg-white border border-pink-100 rounded-2xl p-4 mb-6">
        <p class="text-xs font-semibold text-pink-600 uppercase tracking-wide mb-3">Payment Instructions</p>
        <p class="text-sm text-gray-600 mb-3">Please make a bank transfer for the total amount above:</p>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-500">Bank:</span>
            <span id="conf-bank-name" class="font-medium text-gray-800"></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Sort Code:</span>
            <span id="conf-sort-code" class="font-medium text-gray-800 font-mono"></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Account No:</span>
            <span id="conf-account-no" class="font-medium text-gray-800 font-mono"></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Account Name:</span>
            <span id="conf-account-name" class="font-medium text-gray-800"></span>
          </div>
        </div>
        <div class="mt-3 p-3 bg-pink-50 rounded-xl text-xs text-pink-700 font-medium">
          Reference: Please use your full name as the payment reference
        </div>
        <p class="mt-3 text-xs text-gray-400">
          Estimated dispatch: <span id="conf-dispatch"></span>
        </p>
      </div>

      <button
        id="new-order-btn"
        class="w-full py-3 rounded-xl border border-gray-200 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors"
      >
        Place Another Order
      </button>
    </div>
  </div>
</aside>

<script>
  // ─── Types ───────────────────────────────────────────────────────────────────
  interface OrderItem {
    id: string;
    name: string;
    price: number;
    qty: number;
    variant: string;
    variantName: string;
    category: string;
  }

  // ─── State ───────────────────────────────────────────────────────────────────
  let orderItems: OrderItem[] = [];

  // ─── DOM refs ────────────────────────────────────────────────────────────────
  const sidebar = document.getElementById('order-sidebar')!;
  const overlay = document.getElementById('sidebar-overlay')!;
  const emptyBasket = document.getElementById('empty-basket')!;
  const orderItemsEl = document.getElementById('order-items')!;
  const totalSection = document.getElementById('order-total-section')!;
  const totalEl = document.getElementById('order-total')!;
  const formSection = document.getElementById('checkout-form-section')!;
  const confirmationEl = document.getElementById('order-confirmation')!;
  const basketBadge = document.getElementById('basket-count-badge')!;
  const form = document.getElementById('order-form') as HTMLFormElement;

  // ─── Open / close sidebar ────────────────────────────────────────────────────
  function openSidebar() {
    sidebar.classList.remove('translate-x-full');
    overlay.classList.remove('hidden');
    setTimeout(() => overlay.classList.remove('opacity-0'), 10);
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    sidebar.classList.add('translate-x-full');
    overlay.classList.add('opacity-0');
    setTimeout(() => overlay.classList.add('hidden'), 300);
    document.body.style.overflow = '';
  }

  document.getElementById('basket-toggle')?.addEventListener('click', openSidebar);
  document.getElementById('close-sidebar')?.addEventListener('click', closeSidebar);
  overlay.addEventListener('click', closeSidebar);

  // ─── Render helpers ──────────────────────────────────────────────────────────
  function formatPrice(p: number) {
    return '£' + p.toFixed(2);
  }

  function calcTotal() {
    return orderItems.reduce((sum, item) => sum + item.price * item.qty, 0);
  }

  function renderItems() {
    const total = calcTotal();
    const count = orderItems.reduce((s, i) => s + i.qty, 0);

    // Badge
    basketBadge.textContent = String(count);
    basketBadge.classList.toggle('hidden', count === 0);
    basketBadge.classList.toggle('flex', count > 0);

    if (orderItems.length === 0) {
      emptyBasket.classList.remove('hidden');
      orderItemsEl.classList.add('hidden');
      totalSection.classList.add('hidden');
      formSection.classList.add('hidden');
      return;
    }

    emptyBasket.classList.add('hidden');
    orderItemsEl.classList.remove('hidden');
    totalSection.classList.remove('hidden');
    formSection.classList.remove('hidden');

    orderItemsEl.innerHTML = orderItems.map(item => `
      <div class="flex gap-3 items-start p-3 bg-cream rounded-xl" data-item-id="${item.id}">
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-gray-800 leading-snug">${item.name}</p>
          ${item.variant ? `<p class="text-xs text-gray-500 mt-0.5">${item.variantName}: ${item.variant}</p>` : ''}
          <div class="flex items-center gap-2 mt-2">
            <button class="item-dec w-6 h-6 rounded-full border border-gray-200 text-gray-500 hover:bg-white flex items-center justify-center text-sm" data-id="${item.id}">−</button>
            <span class="text-sm font-medium w-4 text-center">${item.qty}</span>
            <button class="item-inc w-6 h-6 rounded-full border border-gray-200 text-gray-500 hover:bg-white flex items-center justify-center text-sm" data-id="${item.id}">+</button>
          </div>
        </div>
        <div class="text-right flex-shrink-0">
          <p class="text-sm font-bold text-gray-900">${formatPrice(item.price * item.qty)}</p>
          <button class="item-remove text-xs text-red-400 hover:text-red-600 mt-1 transition-colors" data-id="${item.id}">Remove</button>
        </div>
      </div>
    `).join('');

    totalEl.textContent = formatPrice(total);

    // Hidden form fields
    const hiddenItems = document.getElementById('hidden-order-items') as HTMLInputElement;
    const hiddenTotal = document.getElementById('hidden-order-total') as HTMLInputElement;
    if (hiddenItems) hiddenItems.value = orderItems.map(i =>
      `${i.name}${i.variant ? ` (${i.variantName}: ${i.variant})` : ''} × ${i.qty} @ ${formatPrice(i.price)}`
    ).join(' | ');
    if (hiddenTotal) hiddenTotal.value = formatPrice(total);

    // Bind item controls
    orderItemsEl.querySelectorAll<HTMLButtonElement>('.item-dec').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id!;
        const item = orderItems.find(i => i.id === id);
        if (item) {
          if (item.qty <= 1) orderItems = orderItems.filter(i => i.id !== id);
          else item.qty--;
          renderItems();
        }
      });
    });

    orderItemsEl.querySelectorAll<HTMLButtonElement>('.item-inc').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = orderItems.find(i => i.id === btn.dataset.id);
        if (item) { item.qty++; renderItems(); }
      });
    });

    orderItemsEl.querySelectorAll<HTMLButtonElement>('.item-remove').forEach(btn => {
      btn.addEventListener('click', () => {
        orderItems = orderItems.filter(i => i.id !== btn.dataset.id);
        renderItems();
      });
    });
  }

  // ─── Add to order event ──────────────────────────────────────────────────────
  window.addEventListener('add-to-order', (e: Event) => {
    const { id, name, price, qty, variant, variantName, category } = (e as CustomEvent).detail;
    const key = id + (variant ? ':' + variant : '');
    const existing = orderItems.find(i => i.id === key);
    if (existing) {
      existing.qty += qty;
    } else {
      orderItems.push({ id: key, name, price, qty, variant, variantName, category });
    }
    renderItems();
    openSidebar();
  });

  // ─── Form submission ─────────────────────────────────────────────────────────
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const btn = document.getElementById('submit-order-btn') as HTMLButtonElement;
    btn.textContent = 'Placing order…';
    btn.disabled = true;

    const formData = new FormData(form);

    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(formData as unknown as Record<string, string>).toString(),
      });

      if (res.ok || res.status === 303) {
        showConfirmation(formData);
      } else {
        throw new Error('Form submission failed');
      }
    } catch {
      btn.textContent = 'Place Order';
      btn.disabled = false;
      alert('Sorry, there was a problem submitting your order. Please try again or contact us directly.');
    }
  });

  function showConfirmation(formData: FormData) {
    formSection.classList.add('hidden');
    confirmationEl.classList.remove('hidden');

    // Populate confirmation items
    const confItems = document.getElementById('confirmation-items')!;
    confItems.innerHTML = orderItems.map(i =>
      `<div class="flex justify-between"><span>${i.name}${i.variant ? ` (${i.variant})` : ''} × ${i.qty}</span><span class="font-medium">${formatPrice(i.price * i.qty)}</span></div>`
    ).join('');
    const confTotal = document.getElementById('confirmation-total')!;
    confTotal.textContent = formatPrice(calcTotal());

    // Load bank details from settings (injected as data attributes on body by index page)
    const body = document.body;
    document.getElementById('conf-bank-name')!.textContent = body.dataset.bankName || 'TODO: Add bank name';
    document.getElementById('conf-sort-code')!.textContent = body.dataset.bankSortCode || '00-00-00';
    document.getElementById('conf-account-no')!.textContent = body.dataset.bankAccountNumber || '00000000';
    document.getElementById('conf-account-name')!.textContent = body.dataset.bankAccountName || 'L&B Aesthetic Suppliers';
    document.getElementById('conf-dispatch')!.textContent = body.dataset.dispatchTimeframe || '3–5 working days';
  }

  // ─── New order ───────────────────────────────────────────────────────────────
  document.getElementById('new-order-btn')?.addEventListener('click', () => {
    orderItems = [];
    form?.reset();
    confirmationEl.classList.add('hidden');
    renderItems();
  });

  // Initial render
  renderItems();
</script>
