---
// ContactSection.astro
interface Props {
  email: string;
  phone?: string;
  address?: string;
}
const { email, phone, address } = Astro.props;
---

<section id="contact" class="py-20 lg:py-28 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">

      <!-- Left: Info -->
      <div>
        <p class="text-sm font-semibold text-pink-600 tracking-widest uppercase mb-3">Get in Touch</p>
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-gray-900 mb-6">
          Questions?<br />
          <span class="bg-brand-gradient bg-clip-text text-transparent">We're here to help.</span>
        </h2>
        <!-- TODO: replace with real copy before going live -->
        <p class="text-gray-500 leading-relaxed mb-8">
          Whether you want to check product availability, ask about bulk orders, or just need some advice
          on what to stock — get in touch and we'll get back to you as quickly as we can.
        </p>

        <div class="space-y-4">
          {email && (
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg,#FF6B4A20,#D4148A20)">
                <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Email</p>
                <a href={`mailto:${email}`} class="text-sm text-gray-800 font-medium hover:text-pink-600 transition-colors">{email}</a>
              </div>
            </div>
          )}
          {phone && (
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg,#FF6B4A20,#D4148A20)">
                <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Phone</p>
                <a href={`tel:${phone}`} class="text-sm text-gray-800 font-medium hover:text-pink-600 transition-colors">{phone}</a>
              </div>
            </div>
          )}
          {address && (
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background: linear-gradient(135deg,#FF6B4A20,#D4148A20)">
                <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Address</p>
                <p class="text-sm text-gray-800 font-medium whitespace-pre-line">{address}</p>
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- Right: Contact form -->
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
        <h3 class="font-serif font-semibold text-xl text-gray-900 mb-6">Send us a message</h3>

        <!-- Netlify contact form -->
        <form
          id="contact-form"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-5"
          novalidate
        >
          <input type="hidden" name="form-name" value="contact" />
          <div style="display:none">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="contact-name">Name *</label>
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-pink-400"
                placeholder="Jane Smith"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" for="contact-email">Email *</label>
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-pink-400"
                placeholder="jane@yoursalon.com"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="contact-subject">Subject</label>
            <input
              type="text"
              id="contact-subject"
              name="subject"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-pink-400"
              placeholder="Product enquiry, bulk order, etc."
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="contact-message">Message *</label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="5"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-pink-400 resize-none"
              placeholder="How can we help?"
            ></textarea>
          </div>

          <button
            type="submit"
            id="contact-submit-btn"
            class="w-full py-4 rounded-xl font-semibold text-white bg-brand-gradient hover:shadow-lg hover:scale-[1.02] transition-all duration-200"
          >
            Send Message
          </button>
        </form>

        <!-- Contact form success message -->
        <div id="contact-success" class="hidden text-center py-8">
          <div class="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h4 class="font-serif font-bold text-lg text-gray-900 mb-2">Message Sent!</h4>
          <p class="text-sm text-gray-500">Thanks for getting in touch — we'll reply as soon as we can.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const contactForm = document.getElementById('contact-form') as HTMLFormElement;
  const contactSuccess = document.getElementById('contact-success')!;
  const contactBtn = document.getElementById('contact-submit-btn') as HTMLButtonElement;

  contactForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    contactBtn.textContent = 'Sending…';
    contactBtn.disabled = true;

    const formData = new FormData(contactForm);
    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(formData as unknown as Record<string, string>).toString(),
      });
      if (res.ok || res.status === 303) {
        contactForm.classList.add('hidden');
        contactSuccess.classList.remove('hidden');
      } else {
        throw new Error();
      }
    } catch {
      contactBtn.textContent = 'Send Message';
      contactBtn.disabled = false;
      alert('Sorry, there was a problem sending your message. Please email us directly.');
    }
  });
</script>
